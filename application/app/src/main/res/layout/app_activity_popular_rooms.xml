<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_popular_page_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="254dp"
            android:background="@drawable/app_bg_popular_header">

            <TextView
                android:id="@+id/tv_popular_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="58dp"
                android:layout_marginTop="22dp"
                android:fontFamily="sans-serif-medium"
                android:text="10:22"
                android:textColor="@android:color/white"
                android:textSize="18sp" />

            <View
                android:layout_width="126dp"
                android:layout_height="30dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="14dp"
                android:background="@drawable/app_bg_popular_island" />

            <View
                android:layout_width="34dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="23dp"
                android:layout_marginEnd="36dp"
                android:background="@drawable/app_bg_popular_battery" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_popular_tabs"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="58dp"
                android:layout_marginEnd="18dp">

                <TextView
                    android:id="@+id/tv_popular_user_avatar"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/app_bg_popular_profile"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="T"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/ll_popular_tab_labels"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/iv_popular_search"
                    app:layout_constraintStart_toEndOf="@id/tv_popular_user_avatar"
                    app:layout_constraintTop_toTopOf="parent">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:alpha="0.55"
                        android:gravity="center"
                        android:text="Featured"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Popular"
                        android:textColor="@android:color/white"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:alpha="0.55"
                        android:gravity="center"
                        android:text="Discover"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_popular_search"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="5dp"
                    android:src="@drawable/app_ic_popular_search"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <FrameLayout
                android:id="@+id/fl_popular_banner"
                android:layout_width="match_parent"
                android:layout_height="126dp"
                android:layout_gravity="bottom"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/app_bg_popular_banner"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:shadowColor="#88000000"
                    android:shadowDx="0"
                    android:shadowDy="3"
                    android:shadowRadius="5"
                    android:text="Weekly CP"
                    android:textColor="@android:color/white"
                    android:textSize="40sp"
                    android:textStyle="bold|italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/app_bg_popular_banner_pill"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="+500%"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_popular_rooms"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="8dp"
            android:paddingBottom="92dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_popular_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:background="@drawable/app_bg_popular_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <TextView
            style="@style/AppPopularBottomTab"
            android:text="Match" />

        <TextView
            style="@style/AppPopularBottomTab"
            android:text="Group" />

        <TextView
            style="@style/AppPopularBottomTab"
            android:text="Game" />

        <TextView
            style="@style/AppPopularBottomTab"
            android:text="Plaza" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                style="@style/AppPopularBottomTab"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Chat" />

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:background="@drawable/app_bg_popular_chat_badge"
                android:gravity="center"
                android:text="1"
                android:textColor="@android:color/white"
                android:textSize="11sp" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
