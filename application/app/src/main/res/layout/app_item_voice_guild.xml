<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="232dp"
    android:layout_height="match_parent"
    android:layout_marginEnd="12dp"
    app:cardBackgroundColor="@color/app_voice_home_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="#EFE6F8"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_guild_badge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/app_voice_home_guild_badge"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="F"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:textColor="@color/app_voice_home_purple" />

        <TextView
            android:id="@+id/text_guild_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/app_voice_home_on_surface"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/text_guild_badge"
            app:layout_constraintTop_toTopOf="@id/text_guild_badge"
            tools:text="Star Family" />

        <TextView
            android:id="@+id/text_guild_members"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/app_voice_home_on_surface_variant"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/text_guild_badge"
            app:layout_constraintTop_toBottomOf="@id/text_guild_name"
            tools:text="12.8K members" />

        <TextView
            android:id="@+id/text_guild_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="2dp"
            android:maxLines="2"
            android:textColor="@color/app_voice_home_on_surface_variant"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_guild_badge"
            tools:text="Daily room parties and PK teams." />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
