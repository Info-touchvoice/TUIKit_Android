<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_login_background">

    <ImageView
        android:id="@+id/iv_login_hero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.82"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/app_login_hero_shapes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view_login_scrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_login_logo"
        android:layout_width="136dp"
        android:layout_height="88dp"
        android:layout_marginTop="168dp"
        android:contentDescription="@string/app_main_title"
        android:scaleType="fitCenter"
        android:src="@drawable/app_login_logo_mark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_login_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginEnd="52dp"
        android:layout_marginBottom="28dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/app_login_button_apple"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/app_ic_apple" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:includeFontPadding="false"
                android:text="@string/app_login_with_apple"
                android:textColor="@color/app_color_white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_facebook_login"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/app_login_button_facebook"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/app_login_circle_button_white"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/app_login_facebook_symbol"
                android:textColor="#3478F6"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:includeFontPadding="false"
                android:text="@string/app_login_with_facebook"
                android:textColor="@color/app_color_white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_google_login"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/app_login_circle_button_white"
                android:clickable="true"
                android:contentDescription="@string/app_login_with_google"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/app_login_google_symbol"
                android:textColor="#4285F4"
                android:textSize="24sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btn_phone_login"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="42dp"
                android:background="@drawable/app_login_circle_button_gold"
                android:clickable="true"
                android:contentDescription="@string/app_login_with_phone"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/app_ic_phone" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_login_terms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="42dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:textColor="#E6FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>