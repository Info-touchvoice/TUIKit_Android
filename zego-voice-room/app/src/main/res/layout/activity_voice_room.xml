<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_voice_room"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_round_translucent"
            android:contentDescription="@android:string/cancel"
            android:src="@drawable/ic_back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/roomTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/roomSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#D8D2FF"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/roleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_vip_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="@color/black"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/zegoFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginHorizontal="@dimen/space_md"
        android:background="@drawable/bg_zego_container" />

    <TextView
        android:id="@+id/zegoUnavailableNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_md"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_notice"
        android:padding="@dimen/space_sm"
        android:text="@string/zego_credentials_missing"
        android:textColor="@color/white"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/pkPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_md"
        android:background="@drawable/bg_pk_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pk_battle"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pkScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pkButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginStart="@dimen/space_md"
            android:text="PK"
            android:textColor="@color/white"
            app:strokeColor="@color/white" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/seatList"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:layout_marginHorizontal="@dimen/space_md"
        android:clipToPadding="false" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="@dimen/space_md"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_md">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/muteButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/mute"
            android:textAllCaps="false"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_mic" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/giftButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="@dimen/space_sm"
            android:contentDescription="@string/gift"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_gift"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="@string/chat_hint"
            android:paddingHorizontal="@dimen/space_md"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="@dimen/space_sm"
            android:text="@string/send"
            android:textAllCaps="false"
            app:cornerRadius="18dp" />
    </LinearLayout>
</LinearLayout>
